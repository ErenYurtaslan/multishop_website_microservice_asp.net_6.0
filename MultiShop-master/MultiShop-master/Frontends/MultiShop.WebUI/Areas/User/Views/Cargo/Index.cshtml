@model MultiShop.WebUI.Areas.User.Models.UserCargoTrackingViewModel
@{
    ViewData["Title"] = "Kargom Nerede";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
    TimeZoneInfo trTimeZone;
    try
    {
        trTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Turkey Standard Time");
    }
    catch
    {
        trTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Europe/Istanbul");
    }
    DateTime ToTrTime(DateTime dt) => TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(dt, DateTimeKind.Utc), trTimeZone);
}

<div class="container-fluid pb-5">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="bg-light p-30">
                <div class="d-flex flex-wrap mb-3" style="gap:8px;">
                    <a href="/Default/Index/" class="btn btn-sm btn-outline-secondary">Ana Sayfa</a>
                    <a href="/ProductList/Index/" class="btn btn-sm btn-outline-secondary">Ürünler</a>
                    <a href="/User/MyOrder/MyOrderList/" class="btn btn-sm btn-outline-primary">Siparişlerim</a>
                </div>
                <h4 class="mb-3">Kargom Nerede</h4>
                <p class="text-muted mb-3">Sipariş sonrası oluşan kargo kayıtlarınız barkod ve durum adımlarıyla listelenir.</p>

                @if (Model?.CargoCards == null || Model.CargoCards.Count == 0)
                {
                    <div class="alert alert-info mb-0">
                        Size ait kargo kaydı bulunamadı. Yeni siparişten sonra bu alanda kargo durumları görünecektir.
                    </div>
                }
                else
                {
                    @foreach (var card in Model.CargoCards)
                    {
                        <div class="border rounded p-3 mb-3 bg-white">
                            <div class="d-flex justify-content-between align-items-start flex-wrap">
                                <div>
                                    <h5 class="mb-1">Barkod: @card.Barcode</h5>
                                    <small class="text-muted d-block">Kargo Firması: @card.CargoCompanyName</small>
                                    <small class="text-muted d-block">Gönderen: @card.SenderCustomer</small>
                                    <small class="text-muted d-block">Alıcı: @card.ReceiverCustomer</small>
                                </div>
                                <div class="text-right">
                                    <span class="badge badge-primary">@card.LastStatusDescription</span>
                                    <small class="d-block text-muted mt-1">
                                        @(card.LastOperationDate.HasValue ? ToTrTime(card.LastOperationDate.Value).ToString("dd.MM.yyyy HH:mm") : "-")
                                    </small>
                                </div>
                            </div>
                            @if (card.Products != null && card.Products.Count > 0)
                            {
                                <div class="mt-3 mb-2">
                                    <small class="text-muted d-block mb-2">Bu kargodaki ürünler</small>
                                    <div class="d-flex flex-wrap" style="gap:10px;">
                                        @foreach (var p in card.Products)
                                        {
                                            <div class="d-flex align-items-center border rounded px-2 py-1" style="min-width:220px;">
                                                <img src="@p.ProductImageUrl" alt="@p.ProductName" style="width:34px;height:34px;object-fit:cover;border:1px solid #eee;margin-right:8px;" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" />
                                                <small>@p.ProductName <span class="text-muted">(x@(p.Quantity))</span></small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="table-responsive mt-3">
                                <table class="table table-sm table-bordered mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width: 180px;">Tarih</th>
                                            <th>Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (card.Steps.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="2">Henüz operasyon kaydı bulunmuyor.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var step in card.Steps)
                                            {
                                                <tr>
                                                    <td>@ToTrTime(step.OperationDate).ToString("dd.MM.yyyy HH:mm")</td>
                                                    <td>@step.Description</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
