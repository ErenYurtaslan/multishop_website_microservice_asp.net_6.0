@model UpdateProductDto

@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}


<section class="content container-fluid">
    <div class="row">

        <div class="col-md-12">
            <div class="chart-box">
                <h4>Ürün Güncelleme Sayfası</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ProductId" />
                        <label>Ürün Adı</label>
                        <input type="text" class="form-control" asp-for="ProductName" required />
                        <br />
                        <label>Ürün Fiyatı</label>
                        <input type="number" step="0.01" min="0" class="form-control" asp-for="ProductPrice" required />
                        <br />
                        <label>Ürün Görseli</label>
                        <input type="hidden" asp-for="ProductImageUrl" />
                        <input type="file" class="form-control" name="productImageFile" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                        <small class="text-muted">Yeni dosya seçersen mevcut görsel değiştirilir. Seçmezsen mevcut görsel korunur.</small>
                        @if (!string.IsNullOrWhiteSpace(Model?.ProductImageUrl))
                        {
                            <div class="mt-2">
                                <img src="@Model.ProductImageUrl" alt="Mevcut ürün görseli" style="width:90px;height:90px;object-fit:cover;border:1px solid #ddd;padding:2px;" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" />
                            </div>
                        }
                        <br />
                        <div class="row">
                            <div class="col-md-4">
                                <label>Renk</label>
                                <input type="text" class="form-control" asp-for="Color" placeholder="Siyah, Beyaz, Kırmızı..." />
                                <small class="text-muted d-block mt-1">Filtre ikon rengi</small>
                                <input type="color" class="form-control" asp-for="ColorCode" value="@(string.IsNullOrWhiteSpace(Model?.ColorCode) ? "#cccccc" : Model.ColorCode)" />
                            </div>
                            <div class="col-md-4">
                                <label>Beden / Ebat</label>
                                <input type="text" class="form-control" asp-for="Size" placeholder="XS, S, M, L, XL..." />
                            </div>
                            <div class="col-md-4">
                                <label>Stok Adedi</label>
                                <input type="number" min="0" class="form-control" asp-for="Stock" />
                            </div>
                        </div>
                        <br />
                        <label>Ürün Kategorisi</label>
                        @Html.DropDownListFor(x=>x.CategoryId,(List<SelectListItem>)ViewBag.CategoryValues,new {@class="form-control"})
                        <br />
                        <label>Ürün Markası</label>
                        @Html.DropDownListFor(x => x.BrandId, (List<SelectListItem>)ViewBag.BrandValues, "Marka seçiniz", new { @class = "form-control" })
                        <br />
                        <label>Ürün Açıklaması</label>
                        <textarea class="form-control" asp-for="ProductDescription" rows="5" required></textarea>
                        <br />
                        <button class="btn btn-primary">Ürünü Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>