@model List<ResultProductDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <div class="bs-example" data-example-id="bordered-table">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Marka</th>
                                <th>Ürün Fiyatı</th>
                                <th>Renk</th>
                                <th>Beden</th>
                                <th>Stok</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var brandLookup = ViewBag.BrandLookup as Dictionary<string, MultiShop.DtoLayer.CatalogDtos.BrandDtos.ResultBrandDto>
                                                  ?? new Dictionary<string, MultiShop.DtoLayer.CatalogDtos.BrandDtos.ResultBrandDto>();
                            }
                            @foreach (var item in Model)
                            {
                                count++;
                                brandLookup.TryGetValue(item.BrandId ?? string.Empty, out var brand);
                                <tr>
                                    <th scope="row">@count</th>
                                    <td>@item.ProductName</td>
                                    <td>
                                        @if (brand != null)
                                        {
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                <img src="@brand.ImageUrl" alt="@brand.BrandName" style="width:26px;height:26px;object-fit:contain;border:1px solid #ddd;padding:2px;" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" />
                                                <span>@brand.BrandName</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@item.ProductPrice</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Color) ? "-" : item.Color)</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Size) ? "-" : item.Size)</td>
                                    <td>
                                        @if (item.Stock <= 0)
                                        {
                                            <span class="badge badge-danger">Stok yok</span>
                                        }
                                        else
                                        {
                                            <span>@item.Stock</span>
                                        }
                                    </td>
                                    <td><a href="/Admin/Product/DeleteProduct/@item.ProductId" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Admin/Product/UpdateProduct/@item.ProductId" class="btn btn-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="/Admin/Product/CreateProduct/" class="btn btn-primary">Yeni Ürün Girişi</a>
                </div>
            </div>
        </div>
    </div>
</section>
