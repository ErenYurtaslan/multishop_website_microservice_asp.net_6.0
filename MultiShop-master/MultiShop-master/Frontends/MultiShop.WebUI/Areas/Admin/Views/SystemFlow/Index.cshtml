@model MultiShop.WebUI.Areas.Admin.Models.SystemFlowStatusViewModel
@{
    ViewData["Title"] = "Sistem Akışı";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="box box-solid">
                <div class="box-header with-border">
                    <h3 class="box-title"><i class="fa fa-sitemap mr-2"></i>Servis Akışı ve Teknik Notlar (Readonly)</h3>
                </div>
                <div class="box-body">
                    <p class="text-muted mb-0">Bu ekran yalnızca admin panelinden erişilebilir.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title"><i class="fa fa-plug mr-2"></i>Canlı Port Durumu</h3>
                    <small class="text-muted pull-right">Ölçüm: @Model.CheckedAtLocal.ToString("dd.MM.yyyy HH:mm:ss")</small>
                </div>
                <div class="box-body table-responsive">
                    <table class="table table-striped table-condensed mb-0">
                        <thead>
                            <tr>
                                <th>Servis</th>
                                <th>Port</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Ports)
                            {
                                <tr>
                                    <td>@p.Label</td>
                                    <td><code>@p.Port</code></td>
                                    <td>
                                        @if (p.Reachable)
                                        {
                                            <span class="label label-success">Açık</span>
                                        }
                                        else
                                        {
                                            <span class="label label-danger">Kapalı</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <p class="text-muted text-sm mt-2 mb-0">
                        Yerel makinede <code>127.0.0.1</code> üzerinden kısa süreli TCP denemesi yapılır; servis kapalıysa veya firewall engelliyorsa &quot;Kapalı&quot; görünür.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="box box-info">
                <div class="box-header with-border">
                    <h3 class="box-title"><i class="fa fa-file-alt mr-2"></i>Headless Log Dosyaları</h3>
                </div>
                <div class="box-body">
                    @if (string.IsNullOrEmpty(Model.LogsDirectory))
                    {
                        <p class="text-warning mb-0">Log klasörü bulunamadı. Headless başlatma ile oluşan <code>logs</code> dizini bekleniyor.</p>
                    }
                    else
                    {
                        <p class="text-muted text-sm">Klasör: <code>@Model.LogsDirectory</code></p>
                        <table class="table table-striped table-condensed mb-0">
                            <thead>
                                <tr>
                                    <th>Servis</th>
                                    <th>Son yazım</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in Model.Logs)
                                {
                                    <tr>
                                        <td>@l.Name <small class="text-muted">(@l.FileName)</small></td>
                                        <td>
                                            @if (l.Exists && l.LastWriteLocal.HasValue)
                                            {
                                                <span>@l.LastWriteLocal.Value.ToString("HH:mm:ss")</span>
                                                <br /><small class="text-muted">@l.LastWriteLocal.Value.ToString("dd.MM.yyyy")</small>
                                            }
                                            else
                                            {
                                                <span class="label label-default">Yok</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">Kullanıcı ve Kimlik Akışı</h3>
                </div>
                <div class="box-body">
                    <ul>
                        <li>Kullanıcı WebUI'da giriş yapar, token Identity üzerinden alınır.</li>
                        <li>WebUI servis çağrılarını Gateway üstünden yapar.</li>
                        <li>Sepet, Favori, Sipariş, Ödeme çağrıları rol/scope doğrulamasıyla geçer.</li>
                        <li>Admin alanı yalnızca Admin rolüne açıktır.</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="box box-info">
                <div class="box-header with-border">
                    <h3 class="box-title">E-Ticaret Akışı (Demo)</h3>
                </div>
                <div class="box-body">
                    <ol class="pl-3">
                        <li>Ürün seçimi (Catalog)</li>
                        <li>Sepete ekleme (Basket/Redis)</li>
                        <li>Adres doğrulama (Order/Address)</li>
                        <li>Ödeme kaydı (Payment/SQL)</li>
                        <li>Sipariş kaydı (Order/SQL)</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="box box-success">
                <div class="box-header with-border">
                    <h3 class="box-title">Servis Uç Noktaları</h3>
                </div>
                <div class="box-body">
                    <ul>
                        <li>Identity: <code>http://localhost:5001</code></li>
                        <li>Gateway: <code>http://localhost:5000</code></li>
                        <li>WebUI: <code>http://localhost:5178</code></li>
                        <li>Basket: <code>http://localhost:7074</code></li>
                        <li>Order: <code>http://localhost:7072</code></li>
                        <li>Payment: <code>http://localhost:7076</code></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="box box-warning">
                <div class="box-header with-border">
                    <h3 class="box-title">Swagger Kısayolları</h3>
                </div>
                <div class="box-body">
                    <ul>
                        <li>
                            <a href="http://localhost:7074/swagger" target="_blank">Basket Swagger</a><br />
                            <small class="text-muted">Sepet verisinin Redis üzerinde okunması, sepet ürün ekleme/çıkarma ve toplam tutar hesaplarının kontrol edildiği API yüzüdür.</small>
                        </li>
                        <li>
                            <a href="http://localhost:7072/swagger" target="_blank">Order Swagger</a><br />
                            <small class="text-muted">Sipariş ve adres kayıtlarının SQL'e yazılması, sipariş listeleme ve sipariş detaylarının doğrulanması için kullanılan endpointleri içerir.</small>
                        </li>
                        <li>
                            <a href="http://localhost:7076/swagger" target="_blank">Payment Swagger</a><br />
                            <small class="text-muted">Ödeme kaydı oluşturma, toplam ödeme tutarı ve ödeme sonuç bilgilerinin servis tarafında nasıl tutulduğunu kontrol etmeyi sağlar.</small>
                        </li>
                        <li>
                            <a href="http://localhost:7075/swagger" target="_blank">Comment Swagger</a><br />
                            <small class="text-muted">Ürün yorumlarının eklenmesi, aktif/pasif yorum durumlarının yönetimi ve yorum listelerinin doğrulanması için kullanılır.</small>
                        </li>
                        <li>
                            <a href="http://localhost:7073/swagger" target="_blank">Cargo Swagger</a><br />
                            <small class="text-muted">Kargo firması, kargo detay ve operasyon adımlarının oluşturulup takip edildiği endpointleri test etmek için kullanılır.</small>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="box box-default">
                <div class="box-header with-border">
                    <h3 class="box-title">Veri Katmanı Mimarisi</h3>
                </div>
                <div class="box-body">
                    <ul>
                        <li>
                            <strong>SQL Server:</strong> Identity, Order, Cargo, Comment, Discount, Favorite, Payment<br />
                            <small class="text-muted">İlişkisel veri gerektiren kullanıcı, sipariş, kargo, yorum, kupon ve ödeme tabloları bu katmanda tutulur; transaction ve raporlama için uygundur.</small>
                        </li>
                        <li>
                            <strong>MongoDB:</strong> Catalog<br />
                            <small class="text-muted">Ürün, kategori, marka ve vitrin içerikleri gibi şeması esnek katalog verileri doküman yapısıyla saklanır.</small>
                        </li>
                        <li>
                            <strong>PostgreSQL:</strong> Message<br />
                            <small class="text-muted">Kullanıcılar arası mesajlaşma kayıtları ve mesaj listeleri PostgreSQL üzerinde tutulur.</small>
                        </li>
                        <li>
                            <strong>Redis:</strong> Basket<br />
                            <small class="text-muted">Sepet verisi hızlı okuma/yazma için bellek içi olarak Redis'te tutulur; kullanıcı sepetleri anlık olarak yönetilir.</small>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
