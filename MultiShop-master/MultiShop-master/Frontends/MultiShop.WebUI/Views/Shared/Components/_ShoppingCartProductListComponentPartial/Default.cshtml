@model List<BasketItemDto>
@{
    var brandByProductId = ViewBag.BrandByProductId as Dictionary<string, MultiShop.DtoLayer.CatalogDtos.BrandDtos.ResultBrandDto>;
}
<div class="col-lg-8 table-responsive mb-5">
    <table class="table table-light table-borderless table-hover text-center mb-0">
        <thead class="thead-dark">
            <tr>
                <th>Ürün</th>
                <th>Fiyat</th>
                <th>Miktar</th>
                <th>Toplam</th>
                <th>Kaldır</th>
            </tr>
        </thead>
        <tbody class="align-middle">

            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted py-4">
                        Sepetin şu an boş. <a href="/ProductList/Index/" class="text-primary">Ürünlere göz at</a>.
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    var lineTotal = item.Price * item.Quantity;
                    var brand = item.ProductId != null && brandByProductId != null && brandByProductId.TryGetValue(item.ProductId, out var b) ? b : null;
                    <tr>
                        <td class="align-middle text-left">
                            <img src="@(string.IsNullOrWhiteSpace(item.ProductImageUrl) ? "/images/placeholder-product.svg" : item.ProductImageUrl)" alt="" style="width: 50px; height:60px; object-fit:cover;" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';">
                            @item.ProductName
                            @if (brand != null)
                            {
                                <div class="small text-muted mt-1 d-inline-flex align-items-center">
                                    <img src="@brand.ImageUrl" alt="@brand.BrandName" style="width:14px;height:14px;object-fit:contain;margin-right:4px;" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" />
                                    @brand.BrandName
                                </div>
                            }
                        </td>
                        <td class="align-middle">@item.Price ₺</td>
                        <td class="align-middle">
                            <span class="badge badge-secondary px-3 py-2">@item.Quantity</span>
                        </td>
                        <td class="align-middle"><strong>@lineTotal ₺</strong></td>
                        <td class="align-middle"><a href="/ShoppingCart/RemoveBasketItem/@item.ProductId" class="btn btn-sm btn-danger" title="Sepetten çıkar"><i class="fa fa-times"></i></a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>