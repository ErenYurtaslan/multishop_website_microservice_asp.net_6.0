@model List<string>
@{
    var selectedColor = ViewBag.SelectedColor as string;
    var colorHexByName = ViewBag.ColorHexByName as Dictionary<string, string>
                         ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    string ColorToHex(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "#cccccc";
        switch (name.Trim().ToLowerInvariant())
        {
            case "siyah": case "black": return "#111111";
            case "beyaz": case "white": return "#f5f5f5";
            case "mavi": case "blue": return "#1e88e5";
            case "kirmizi": case "kırmızı": case "red": return "#e53935";
            case "yesil": case "yeşil": case "green": return "#43a047";
            case "sari": case "sarı": case "yellow": return "#fdd835";
            case "turuncu": case "orange": return "#fb8c00";
            case "mor": case "purple": return "#8e24aa";
            case "pembe": case "pink": return "#ec407a";
            case "kahverengi": case "brown": return "#6d4c41";
            case "gri": case "gray": case "grey": return "#9e9e9e";
            case "lacivert": case "navy": return "#1a237e";
            case "bej": case "beige": return "#d7ccc8";
            default: return "#cccccc";
        }
    }
}

<h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Renge Göre Filtrele</span></h5>
<div class="bg-light p-4 mb-30">
    <div class="custom-control custom-radio d-flex align-items-center mb-3">
        <input form="productFilterForm" type="radio" class="custom-control-input" name="color" id="color-all" value=""
               @(string.IsNullOrEmpty(selectedColor) ? "checked" : "") />
        <label class="custom-control-label" for="color-all">Tüm Renkler</label>
    </div>
    @if (Model == null || Model.Count == 0)
    {
        <small class="text-muted">Henüz renk bilgisi olan ürün yok.</small>
    }
    else
    {
        var i = 0;
        foreach (var color in Model)
        {
            i++;
            var inputId = $"color-{i}";
            var hex = colorHexByName.TryGetValue(color ?? string.Empty, out var customHex) &&
                      !string.IsNullOrWhiteSpace(customHex)
                ? customHex
                : ColorToHex(color);
            var border = (color != null && color.Trim().Equals("Beyaz", StringComparison.OrdinalIgnoreCase))
                         ? "border:1px solid #bbb;"
                         : "border:1px solid rgba(0,0,0,0.15);";
            <div class="custom-control custom-radio d-flex align-items-center mb-3">
                <input form="productFilterForm" type="radio" class="custom-control-input" name="color"
                       id="@inputId" value="@color"
                       @(string.Equals(selectedColor, color, StringComparison.OrdinalIgnoreCase) ? "checked" : "") />
                <label class="custom-control-label d-flex align-items-center mb-0" for="@inputId" style="cursor:pointer;">
                    <span class="d-inline-block mr-2" style="width:18px;height:18px;border-radius:50%;@border background-color:@hex;flex-shrink:0;"></span>
                    <span>@color</span>
                </label>
            </div>
        }
    }
</div>
