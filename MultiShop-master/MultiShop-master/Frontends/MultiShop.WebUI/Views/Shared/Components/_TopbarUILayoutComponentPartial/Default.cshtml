<div class="container-fluid">
    
    <div class="row align-items-center bg-light py-3 px-xl-5 d-none d-lg-flex">
        <div class="col-lg-4">
            <a href="/Default/Index/" class="text-decoration-none">
                <span class="h1 text-uppercase text-primary bg-dark px-2">Multi</span>
                <span class="h1 text-uppercase text-dark bg-primary px-2 ml-n1">Shop</span>
            </a>
        </div>
        <div class="col-lg-4 col-6 text-left">
            <form method="get" action="/ProductList/Index">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Aranacak Ürünü Giriniz" value="@(Context.Request.Query["search"].ToString())" />
                    <div class="input-group-append">
                        <button type="submit" class="input-group-text bg-transparent text-primary border-0" style="cursor:pointer;">
                            <i class="fa fa-search"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
        <div class="col-lg-4 col-6 text-right">
            <p class="m-0">Telefon Numaramız</p>
            <h5 class="m-0">+90 123 456 6789</h5>
        </div>
    </div>
</div>