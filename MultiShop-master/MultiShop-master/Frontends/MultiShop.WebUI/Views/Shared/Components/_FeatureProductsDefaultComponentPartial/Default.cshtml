@model List<ResultProductDto>
@{
    var returnEnc = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
    string FpImg(ResultProductDto i) => string.IsNullOrWhiteSpace(i?.ProductImageUrl) ? "/images/placeholder-product.svg" : i.ProductImageUrl;
    var brandLookup = ViewBag.BrandLookup as Dictionary<string, MultiShop.DtoLayer.CatalogDtos.BrandDtos.ResultBrandDto>
                      ?? new Dictionary<string, MultiShop.DtoLayer.CatalogDtos.BrandDtos.ResultBrandDto>();
    var ratingLookup = ViewBag.RatingSummaryByProductId as Dictionary<string, MultiShop.WebUI.ViewComponents.DefaultViewComponents._FeatureProductsDefaultComponentPartial.ProductRatingSummary>
                      ?? new Dictionary<string, MultiShop.WebUI.ViewComponents.DefaultViewComponents._FeatureProductsDefaultComponentPartial.ProductRatingSummary>();
}

<div class="container-fluid pt-5 pb-3">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4"><span class="bg-secondary pr-3">Öne Çıkan Ürünler</span></h2>
    <div class="row px-xl-5">

        @foreach (var item in Model)
        { 
            decimal x = ((item.ProductPrice / 100) * 15) + item.ProductPrice;
            var outOfStockFp = item.Stock <= 0;
            brandLookup.TryGetValue(item.BrandId ?? string.Empty, out var brand);
            ratingLookup.TryGetValue(item.ProductId ?? string.Empty, out var ratingSummary);
            var reviewCount = ratingSummary?.ReviewCount ?? 0;
            var averageRating = ratingSummary?.AverageRating ?? 0d;
            var averageRatingText = averageRating.ToString("0.0");
            var roundedToHalf = Math.Round(averageRating * 2, MidpointRounding.AwayFromZero) / 2.0;
            var fullStarCount = (int)Math.Floor(roundedToHalf);
            var hasHalfStar = (roundedToHalf - fullStarCount) >= 0.5;
            var emptyStarCount = 5 - fullStarCount - (hasHalfStar ? 1 : 0);
            if (emptyStarCount < 0) { emptyStarCount = 0; }

            <div class="col-lg-3 col-md-4 col-sm-6 pb-1">
                <div class="product-item bg-light mb-4">
                    <div class="product-img position-relative overflow-hidden">
                        <img class="img-fluid w-100" src="@FpImg(item)" alt="" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';">
                        @if (outOfStockFp)
                        {
                            <span class="badge badge-danger position-absolute" style="top:10px;left:10px;">Stok yok</span>
                        }
                        <div class="product-action">
                            @if (outOfStockFp)
                            {
                                <span class="btn btn-outline-secondary btn-square" title="Stok yok"><i class="fa fa-shopping-cart"></i></span>
                            }
                            else
                            {
                                <a class="btn btn-outline-dark btn-square" href="/ShoppingCart/AddBasketItem/@item.ProductId?returnUrl=@returnEnc" title="Sepete ekle"><i class="fa fa-shopping-cart"></i></a>
                            }
                            <a class="btn btn-outline-dark btn-square" href="/Favorite/Add/@item.ProductId?returnUrl=@returnEnc" title="Favorilere ekle"><i class="far fa-heart"></i></a>
                            <a class="btn btn-outline-dark btn-square" href="/ProductList/ProductDetail/@item.ProductId" title="Detayı incele"><i class="fa fa-sync-alt"></i></a>
                            <a class="btn btn-outline-dark btn-square" href="/ProductList/ProductDetail/@item.ProductId" title="Detay görünümü"><i class="fa fa-search"></i></a>
                        </div>
                    </div>
                    <div class="text-center py-4">
                        <a class="h6 text-decoration-none text-truncate" href="/ProductList/ProductDetail/@item.ProductId">@item.ProductName</a>
                        <div class="d-flex align-items-center justify-content-center mt-2">
                            <h5>@item.ProductPrice ₺</h5><h6 class="text-muted ml-2"><del>@x ₺</del></h6>
                        </div>
                        <div class="d-flex align-items-center justify-content-center mb-1">
                            @if (brand != null)
                            {
                                <small class="text-muted mr-2 d-inline-flex align-items-center">
                                    <img src="@brand.ImageUrl" alt="@brand.BrandName" style="width:16px;height:16px;object-fit:contain;margin-right:4px;" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';" />
                                    @brand.BrandName
                                </small>
                            }
                        </div>
                        <div class="d-flex align-items-center justify-content-center mb-0">
                            @if (reviewCount > 0)
                            {
                                <small class="text-muted mr-2">@averageRatingText</small>
                            }
                            <div class="text-primary mr-2">
                                @if (reviewCount > 0)
                                {
                                    @for (var i = 0; i < fullStarCount; i++)
                                    {
                                        <small class="fas fa-star"></small>
                                    }
                                    @if (hasHalfStar)
                                    {
                                        <small class="fas fa-star-half-alt"></small>
                                    }
                                    @for (var i = 0; i < emptyStarCount; i++)
                                    {
                                        <small class="far fa-star"></small>
                                    }
                                }
                                else
                                {
                                    @for (var i = 0; i < 5; i++)
                                    {
                                        <small class="far fa-star"></small>
                                    }
                                }
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-center mb-1">
                            @if (reviewCount > 0)
                            {
                                <small>(@reviewCount değerlendirme)</small>
                            }
                            else
                            {
                                <small>(henüz değerlendirilmemiş)</small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }


    </div>
</div>