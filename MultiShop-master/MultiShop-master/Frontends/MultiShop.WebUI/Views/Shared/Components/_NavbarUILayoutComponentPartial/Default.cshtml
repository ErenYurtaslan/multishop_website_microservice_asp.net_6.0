@model List<ResultCategoryDto>
<div class="container-fluid bg-dark mb-30">
    <div class="row px-xl-5">
        <div class="col-lg-3 d-none d-lg-block">
            <a class="btn d-flex align-items-center justify-content-between bg-primary w-100" data-toggle="collapse" href="#navbar-vertical" style="height: 65px; padding: 0 30px;">
                <h6 class="text-dark m-0"><i class="fa fa-bars mr-2"></i>Kategoriler</h6>
                <i class="fa fa-angle-down text-dark"></i>
            </a>
            <nav class="collapse position-absolute navbar navbar-vertical navbar-light align-items-start p-0 bg-light" id="navbar-vertical" style="width: calc(100% - 30px); z-index: 999;">
                <div class="navbar-nav w-100">
                    @foreach (var item in Model)
                    {
                        <a href="/ProductList/Index/@item.CategoryID" class="nav-item nav-link">@item.CategoryName</a>
                    }
                </div>
            </nav>
        </div>
        <div class="col-lg-9">
            <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-3 py-lg-0 px-0">
                <a href="/Default/Index/" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-dark bg-light px-2">Multi</span>
                    <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Shop</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a href="/Default/Index/" class="nav-item nav-link">Ana Sayfa</a>
                        <a href="/ProductList/Index/" class="nav-item nav-link">Ürünler</a>
                        <a href="/Brand/Index/" class="nav-item nav-link">Markalar</a>
                        <div class="nav-item dropdown">
                            <a href="javascript:void(0)" class="nav-link dropdown-toggle" data-toggle="dropdown">Sayfalar <i class="fa fa-angle-down mt-1"></i></a>
                            <div class="dropdown-menu bg-primary rounded-0 border-0 m-0">
                                <a href="/ShoppingCart/Index/" class="dropdown-item">Sepetim</a>
                                <a href="/Order/Index/" class="dropdown-item">Ödeme</a>
                                @if (User?.Identity?.IsAuthenticated == true)
                                {
                                    <a href="/User/MyOrder/MyOrderList/" class="dropdown-item">Siparişlerim</a>
                                    <a href="/User/Cargo/Index/" class="dropdown-item">Kargom Nerede</a>
                                    <a href="/Favorite/Index/" class="dropdown-item">Favorilerim</a>
                                    <a href="/User/Index/" class="dropdown-item">Profilim</a>
                                    <a href="/Login/LogOut/" class="dropdown-item">Çıkış Yap</a>
                                }
                                else
                                {
                                    <a href="/Register/Index/" class="dropdown-item">Kayıt Ol</a>
                                    <a href="/Login/Index/" class="dropdown-item">Giriş Yap</a>
                                }
                            </div>
                        </div>
                        <a href="/Contact/Index/" class="nav-item nav-link">İletişim</a>
                    </div>
                    <div class="navbar-nav ml-auto py-0 d-none d-lg-block">
                        @if (User?.IsInRole("Admin") == true)
                        {
                            <a href="/Admin/Statistic/Index/" class="nav-item nav-link text-warning font-weight-bold px-0 mr-3">
                                <i class="fa fa-shield-alt mr-1"></i>Admin Paneli
                            </a>
                        }
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <span class="nav-item nav-link text-white-50 px-0 mr-3" style="cursor:default;">
                                <i class="fa fa-user-circle text-primary mr-1"></i>
                                Hoş geldin, <strong class="text-light">@(User.Identity.Name ?? "Kullanıcı")</strong>
                            </span>
                            <a href="/Login/LogOut/" class="nav-item nav-link text-light px-0 mr-3">
                                <i class="fa fa-sign-out-alt text-primary mr-1"></i>Çıkış Yap
                            </a>
                        }
                        else
                        {
                            <a href="/Login/Index/" class="nav-item nav-link text-light px-0 mr-3">
                                <i class="fa fa-sign-in-alt text-primary mr-1"></i>Giriş Yap
                            </a>
                        }
                        <a href="/Favorite/Index" class="btn px-0" title="Favorilerim">
                            <i class="fas fa-heart text-primary"></i>
                            <span class="badge text-secondary border border-secondary rounded-circle" style="padding-bottom: 2px;">@(ViewBag.FavoriteCount ?? 0)</span>
                        </a>
                        <a href="/ShoppingCart/Index/" class="btn px-0 ml-3" title="Sepetim">
                            <i class="fas fa-shopping-cart text-primary"></i>
                            <span class="badge text-secondary border border-secondary rounded-circle" style="padding-bottom: 2px;">@(ViewBag.BasketCount ?? 0)</span>
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </div>
</div>