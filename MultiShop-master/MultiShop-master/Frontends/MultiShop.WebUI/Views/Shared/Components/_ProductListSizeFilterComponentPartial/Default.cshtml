@model List<string>
@{
    var selectedSize = ViewBag.SelectedSize as string;
}

<h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Ebata Göre Filtrele</span></h5>
<div class="bg-light p-4 mb-30">
    <div class="custom-control custom-radio d-flex align-items-center justify-content-between mb-3">
        <input form="productFilterForm" type="radio" class="custom-control-input" name="size" id="size-all" value=""
               @(string.IsNullOrEmpty(selectedSize) ? "checked" : "") />
        <label class="custom-control-label" for="size-all">Tüm Ebatlar</label>
    </div>
    @if (Model == null || Model.Count == 0)
    {
        <small class="text-muted">Henüz ebat bilgisi olan ürün yok.</small>
    }
    else
    {
        var i = 0;
        foreach (var size in Model)
        {
            i++;
            var inputId = $"size-{i}";
            <div class="custom-control custom-radio d-flex align-items-center justify-content-between mb-3">
                <input form="productFilterForm" type="radio" class="custom-control-input" name="size"
                       id="@inputId" value="@size"
                       @(string.Equals(selectedSize, size, StringComparison.OrdinalIgnoreCase) ? "checked" : "") />
                <label class="custom-control-label" for="@inputId">@size</label>
            </div>
        }
    }
</div>
