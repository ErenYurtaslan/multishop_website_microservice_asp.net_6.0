@model List<ResultAboutDto>
<div class="container-fluid bg-dark text-secondary mt-5 pt-5">
    <div class="row px-xl-5 pt-5">
        @foreach(var item in Model)
        {
            <div class="col-lg-4 col-md-12 mb-5 pr-3 pr-xl-5">
                <h5 class="text-secondary text-uppercase mb-4">Hakkımızda</h5>
                <p class="mb-4">@item.Description</p>
                <p class="mb-2"><i class="fa fa-map-marker-alt text-primary mr-3"></i>@item.Address</p>
                <p class="mb-2"><i class="fa fa-envelope text-primary mr-3"></i>@item.Email</p>
                <p class="mb-0"><i class="fa fa-phone-alt text-primary mr-3"></i>@item.Phone</p>
            </div>
            
        }
        
        <div class="col-lg-8 col-md-12">
            <div class="row">
                <div class="col-md-4 mb-5">
                    <h5 class="text-secondary text-uppercase mb-4">Hızlı Alışveriş</h5>
                    <div class="d-flex flex-column justify-content-start">
                        <a class="text-secondary mb-2" href="/Default/Index/"><i class="fa fa-angle-right mr-2"></i>Ana Sayfa</a>
                        <a class="text-secondary mb-2" href="/ProductList/Index/"><i class="fa fa-angle-right mr-2"></i>Ürünlerimiz</a>
                        <a class="text-secondary mb-2" href="/ProductList/Index/?inStockOnly=true"><i class="fa fa-angle-right mr-2"></i>Stoktakiler</a>
                        <a class="text-secondary mb-2" href="/ShoppingCart/Index/"><i class="fa fa-angle-right mr-2"></i>Sepetim</a>
                        <a class="text-secondary mb-2" href="/Favorite/Index/"><i class="fa fa-angle-right mr-2"></i>Favorilerim</a>
                        <a class="text-secondary" href="/Contact/Index/"><i class="fa fa-angle-right mr-2"></i>Bize Yazın</a>
                    </div>
                </div>
                <div class="col-md-4 mb-5">
                    <h5 class="text-secondary text-uppercase mb-4">Hesabım</h5>
                    <div class="d-flex flex-column justify-content-start">
                        <a class="text-secondary mb-2" href="/User/Index/"><i class="fa fa-angle-right mr-2"></i>Profilim</a>
                        <a class="text-secondary mb-2" href="/User/MyOrder/Index/"><i class="fa fa-angle-right mr-2"></i>Alışverişlerim</a>
                        <a class="text-secondary mb-2" href="/ShoppingCart/Index/"><i class="fa fa-angle-right mr-2"></i>Sepet Detaylarım</a>
                        <a class="text-secondary mb-2" href="/Favorite/Index/"><i class="fa fa-angle-right mr-2"></i>Favorilerim</a>
                        <a class="text-secondary mb-2" href="/Login/LogOut/"><i class="fa fa-angle-right mr-2"></i>Çıkış Yap</a>
                        <a class="text-secondary" href="/Contact/Index/"><i class="fa fa-angle-right mr-2"></i>İletişim</a>
                    </div>
                </div>
                <div class="col-md-4 mb-5">
                    <h5 class="text-secondary text-uppercase mb-4">Mail Bülteni</h5>
                    @{
                        var newsletterStatus = ViewBag.NewsletterStatus as MultiShop.WebUI.Services.NewsletterServices.NewsletterStatusDto;
                        var reauthRequired = ViewBag.NewsletterReauthRequired is bool b && b;
                        var isAuthenticated = User?.Identity?.IsAuthenticated == true;
                        var returnPath = $"{Context.Request.Path}{Context.Request.QueryString}";
                        var nlMsg = TempData["NewsletterMessage"] as string;
                        var nlType = TempData["NewsletterMessageType"] as string ?? "success";
                    }

                    @if (!string.IsNullOrEmpty(nlMsg))
                    {
                        <div class="alert alert-@nlType py-2 px-3 mb-3" style="font-size: 0.9rem;">@nlMsg</div>
                    }

                    @if (isAuthenticated && reauthRequired)
                    {
                        <p>Hesabın güncellendi. Bültene abone olabilmek için lütfen tekrar giriş yap.</p>
                        <a class="btn btn-warning btn-block" href="/Login/LogOut?returnUrl=@Uri.EscapeDataString(returnPath)">
                            <i class="fa fa-sync-alt mr-1"></i> Tekrar Giriş Yap
                        </a>
                    }
                    else if (!isAuthenticated)
                    {
                        <p>En son indirimler ve kampanyalar için bültene abone ol. Üye değilsen önce kayıt olman gerek.</p>
                        <a class="btn btn-primary btn-block" href="/Register/Index">
                            <i class="fa fa-user-plus mr-1"></i> Kayıt Ol &amp; Abone Ol
                        </a>
                        <small class="text-secondary d-block mt-2">
                            Zaten üye misin? <a class="text-primary" href="/Login/Index">Giriş yap</a>
                        </small>
                    }
                    else if (newsletterStatus != null && newsletterStatus.IsSubscribed)
                    {
                        <p>
                            <strong class="text-light">@newsletterStatus.Email</strong>
                            adresiyle bültene abonesin.
                        </p>
                        <form method="post" action="/Newsletter/Unsubscribe">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@returnPath" />
                            <button type="submit" class="btn btn-outline-light btn-block">
                                <i class="fa fa-bell-slash mr-1"></i> Aboneliği Bırak
                            </button>
                        </form>
                    }
                    else
                    {
                        <p>
                            <strong class="text-light">@(newsletterStatus?.Email ?? User.Identity.Name)</strong>
                            adresiyle bültene abone olmak için tek tık yeterli.
                        </p>
                        <form method="post" action="/Newsletter/Subscribe">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@returnPath" />
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fa fa-paper-plane mr-1"></i> Abone Ol
                            </button>
                        </form>
                    }
                    <h6 class="text-secondary text-uppercase mt-4 mb-3">Bizi Takip Edin</h6>
                    <div class="d-flex">
                        <a class="btn btn-primary btn-square mr-2" href="javascript:void(0)"><i class="fab fa-twitter"></i></a>
                        <a class="btn btn-primary btn-square mr-2" href="javascript:void(0)"><i class="fab fa-facebook-f"></i></a>
                        <a class="btn btn-primary btn-square mr-2" href="javascript:void(0)"><i class="fab fa-linkedin-in"></i></a>
                        <a class="btn btn-primary btn-square" href="javascript:void(0)"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row border-top mx-xl-5 py-4" style="border-color: rgba(256, 256, 256, .1) !important;">
        <div class="col-md-6 px-xl-0">
            <p class="mb-md-0 text-center text-md-left text-secondary">
                &copy; <a class="text-primary" href="/Default/Index/">MultiShop</a>. Tüm hakları saklıdır.
                
                
            </p>
        </div>
        <div class="col-md-6 px-xl-0 text-center text-md-right">
            <img class="img-fluid" src="~/online-shop-website-template/img/payments.png" alt="">
        </div>
    </div>
</div>