@model List<ResultCategoryDto>
@{
    var counts = (ViewBag.CategoryCounts as Dictionary<string, int>) ?? new Dictionary<string, int>();
    string CatImg(string url) => string.IsNullOrWhiteSpace(url) ? "/images/placeholder-product.svg" : url;
}

<div class="container-fluid pt-5">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4"><span class="bg-secondary pr-3">Öne Çıkan Kategoriler</span></h2>
    <div class="row px-xl-5 pb-3">

        @foreach(var item in Model)
        {
            if (item == null) { continue; }
            var categoryId = item?.CategoryID?.Trim() ?? string.Empty;
            var count = counts.ContainsKey(categoryId) ? counts[categoryId] : 0;
       <div class="col-lg-3 col-md-4 col-sm-6 pb-1">
            <a class="text-decoration-none" href="/ProductList/Index/@categoryId">
                <div class="cat-item d-flex align-items-center mb-4">
                    <div class="overflow-hidden" style="width: 100px; height: 100px;">
                        <img class="img-fluid" src="@CatImg(item.ImageUrl)" alt="@(item.CategoryName ?? "Kategori")" onerror="this.onerror=null;this.src='/images/placeholder-product.svg';">
                    </div>
                    <div class="flex-fill pl-3">
                        <h6>@item.CategoryName</h6>
                        <small class="text-body">@count Ürün</small>
                    </div>
                </div>
            </a>
        </div>
        }
    </div>
</div>