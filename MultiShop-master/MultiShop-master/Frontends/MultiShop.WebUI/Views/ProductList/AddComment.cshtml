@{
    var productId = (ViewBag.ProductId as string) ?? (ViewBag.x as string);
    var defaultName = (ViewBag.CommentNameSurname as string) ?? string.Empty;
    var defaultEmail = (ViewBag.CommentEmail as string) ?? string.Empty;
    var selectedRating = (ViewBag.CommentRating as string) ?? "5";
    var defaultCommentDetail = (ViewBag.CommentDetail as string) ?? string.Empty;
}
<div class="col-lg-5 mt-4 mt-lg-0">
    <div class="bg-white border rounded p-3 p-md-4">
    <h5 class="mb-2">Bir Yorum Bırakın</h5>
    <small class="text-muted d-block mb-3">Yorumunuz için geçerli bir email adresi giriniz.</small>
    <form method="post" asp-action="AddComment" asp-controller="ProductList">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ProductId" value="@productId" />
        <div class="form-group">
            <label for="rating">Ürün puanınız *</label>
            <select class="form-control" id="rating" name="Rating">
                <option value="5" selected="@(selectedRating == "5")">5 - Mükemmel</option>
                <option value="4" selected="@(selectedRating == "4")">4 - Çok iyi</option>
                <option value="3" selected="@(selectedRating == "3")">3 - İyi</option>
                <option value="2" selected="@(selectedRating == "2")">2 - Ortalama</option>
                <option value="1" selected="@(selectedRating == "1")">1 - Kötü</option>
            </select>
        </div>
        <div class="form-group">
            <label for="name">Adınız soyadınız *</label>
            <input type="text" class="form-control" id="name" name="NameSurname" value="@defaultName" required>
        </div>
        <div class="form-group">
            <label for="email">Email adresiniz *</label>
            <input type="email" class="form-control" id="email" name="Email" value="@defaultEmail" required>
        </div>
        <div class="form-group">
            <label for="message">Yorumunuz *</label>
            <textarea id="message" cols="30" rows="5" class="form-control" name="CommentDetail" required>@defaultCommentDetail</textarea>
        </div>
        <div class="form-group mb-0">
            <input type="submit" value="Yorum Yap" class="btn btn-primary px-3">
        </div>
    </form>
    </div>
</div>
